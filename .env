# Database
DB_NAME=authdb
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=2004

# JWT — secret must be 64+ characters
APPLICATION_JWT_SECRET=replace-this-with-a-64-char-minimum-random-secret-string-here-ok
APPLICATION_JWT_ACCESS_TOKEN_EXPIRY=900000
APPLICATION_JWT_REFRESH_TOKEN_EXPIRY=604800000

# Rate limiting
APPLICATION_RATE_LIMIT_CAPACITY=20
APPLICATION_RATE_LIMIT_REFILL_TOKENS=20
APPLICATION_RATE_LIMIT_REFILL_DURATION_SECONDS=60

# Redis
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200
